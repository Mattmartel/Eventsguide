{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/icons/**",
              "components/content/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/businessdesk-website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Newsreader|Source Serif 4|Feature Text App|Tiempos Text|Söhne|Circular Std))/i]",
        "message": "Font not provided by the design system. Available: Inter, Newsreader, Source Serif 4, Feature Text App, Tiempos Text, Söhne, Circular Std."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|children|onClose|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: tone, title, children, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|success|error|premium)$/]",
        "message": "<Alert> tone must be one of 'info' | 'success' | 'error' | 'premium'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArticleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:layout|category|kicker|title|standfirst|image|imageAlt|href|premium|live|sponsored|timestamp|comments|rating|headlineSize|key|ref|className|style|children)$/]",
        "message": "<ArticleCard> doesn't accept that prop. Declared props: layout, category, kicker, title, standfirst, image, imageAlt, href, premium, live, sponsored, timestamp, comments, rating, headlineSize."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArticleCard'] > JSXAttribute[name.name='layout'] > Literal[value!=/^(?:text-below|image-left|headline|hero)$/]",
        "message": "<ArticleCard> layout must be one of 'text-below' | 'image-left' | 'headline' | 'hero'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:premium|live|sponsored|neutral|opinion)$/]",
        "message": "<Badge> tone must be one of 'premium' | 'live' | 'sponsored' | 'neutral' | 'opinion'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|fullWidth|disabled|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, fullWidth, disabled, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|red|premium|secondary|outline|ghost|invert)$/]",
        "message": "<Button> variant must be one of 'primary' | 'red' | 'premium' | 'secondary' | 'outline' | 'ghost' | 'invert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Byline'] > JSXAttribute > JSXIdentifier[name!=/^(?:author|avatar|role|timestamp|readTime|size|showAvatar|key|ref|className|style|children)$/]",
        "message": "<Byline> doesn't accept that prop. Declared props: author, avatar, role, timestamp, readTime, size, showAvatar."
      },
      {
        "selector": "JSXOpeningElement[name.name='Byline'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Byline> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, label, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommentBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:author|avatar|subscriber|timestamp|likes|depth|children|key|ref|className|style|children)$/]",
        "message": "<CommentBlock> doesn't accept that prop. Declared props: author, avatar, subscriber, timestamp, likes, depth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|weight|color|spacing|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: label, weight, color, spacing."
      },
      {
        "selector": "JSXOpeningElement[name.name='FooterColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:heading|links|key|ref|className|style|children)$/]",
        "message": "<FooterColumn> doesn't accept that prop. Declared props: heading, links."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|filled|small|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, filled, small."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|prefix|suffix|containerStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, prefix, suffix, containerStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:height|color|title|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: height, color, title."
      },
      {
        "selector": "JSXOpeningElement[name.name='MarketIndex'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|value|change|pct|dir|key|ref|className|style|children)$/]",
        "message": "<MarketIndex> doesn't accept that prop. Declared props: name, value, change, pct, dir."
      },
      {
        "selector": "JSXOpeningElement[name.name='MarketIndex'] > JSXAttribute[name.name='dir'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<MarketIndex> dir must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Masthead'] > JSXAttribute > JSXIdentifier[name!=/^(?:signedIn|userName|onMenu|onSearch|key|ref|className|style|children)$/]",
        "message": "<Masthead> doesn't accept that prop. Declared props: signedIn, userName, onMenu, onSearch."
      },
      {
        "selector": "JSXOpeningElement[name.name='Radio'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|name|value|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Radio> doesn't accept that prop. Declared props: checked, onChange, label, name, value, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:sections|active|onSelect|key|ref|className|style|children)$/]",
        "message": "<SectionNav> doesn't accept that prop. Declared props: sections, active, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|containerStyle|children|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, hint, error, containerStyle, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|gap|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: value, max, size, gap."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|variant|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: category, variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:text|chip)$/]",
        "message": "<Tag> variant must be one of 'text' | 'chip'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|action|onAction|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: children, icon, action, onAction."
      }
    ]
  },
